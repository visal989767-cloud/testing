# ─── MongoDB ───────────────────────────────────────────
# Paste your Atlas connection string here
MONGODB_URI=mongodb://localhost:27017/project-sa

# ─── JWT ───────────────────────────────────────────────
# Any long random string (e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ─── Email (for password reset) ────────────────────────
# Use Gmail App Password or any SMTP provider
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=Project SA <your_email@gmail.com>

# ─── App ───────────────────────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:3000
